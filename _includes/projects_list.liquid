{% assign display_project_categories = include.display_categories | default: page.display_categories %}

<div class="publications">
{% if site.enable_project_categories and display_project_categories %}
  {% for category in display_project_categories %}
    {% case category %}
      {% when "open-source" %}
        {% assign category_label = "Open Source" %}
      {% else %}
        {% assign category_label = category %}
    {% endcase %}
    {% assign categorized_projects = site.projects | where: "category", category | where_exp: "project", "project.hide_from_projects != true" %}
    {% assign categorized_code_projects = site.data.code_projects | where: "category", category %}
    {% assign sorted_projects = categorized_projects | sort: "importance" %}
    {% assign sorted_code_projects = categorized_code_projects | sort: "importance" %}
    {% assign category_project_count = sorted_projects.size | plus: sorted_code_projects.size %}
    {% if category_project_count > 0 %}
      <h2 class="bibliography" id="{{ category }}">{{ category_label }}</h2>
      <ol class="bibliography">
      {% for project in sorted_projects %}
        {% case project.category %}
          {% when "research" %}
            {% assign badge_color = "#6f42c1" %}
          {% when "robotics" %}
            {% assign badge_color = "#0b7285" %}
          {% when "open-source" %}
            {% assign badge_color = "#2f9e44" %}
          {% else %}
            {% assign badge_color = "#6c757d" %}
        {% endcase %}
        {% include project_list_item.liquid project=project badge_color=badge_color %}
      {% endfor %}
      {% for project in sorted_code_projects %}
        {% case project.category %}
          {% when "research" %}
            {% assign badge_color = "#6f42c1" %}
          {% when "robotics" %}
            {% assign badge_color = "#0b7285" %}
          {% when "open-source" %}
            {% assign badge_color = "#2f9e44" %}
          {% else %}
            {% assign badge_color = "#6c757d" %}
        {% endcase %}
        {% include project_list_item.liquid project=project badge_color=badge_color %}
      {% endfor %}
      </ol>
    {% endif %}
  {% endfor %}
{% else %}
  {% assign visible_projects = site.projects | where_exp: "project", "project.hide_from_projects != true" %}
  {% assign sorted_projects = visible_projects | sort: "importance" %}
  {% assign sorted_code_projects = site.data.code_projects | sort: "importance" %}
  <ol class="bibliography">
    {% for project in sorted_projects %}
      {% case project.category %}
        {% when "research" %}
          {% assign badge_color = "#6f42c1" %}
        {% when "robotics" %}
          {% assign badge_color = "#0b7285" %}
        {% when "open-source" %}
          {% assign badge_color = "#2f9e44" %}
        {% else %}
          {% assign badge_color = "#6c757d" %}
      {% endcase %}
      {% include project_list_item.liquid project=project badge_color=badge_color %}
    {% endfor %}
    {% for project in sorted_code_projects %}
      {% case project.category %}
        {% when "research" %}
          {% assign badge_color = "#6f42c1" %}
        {% when "robotics" %}
          {% assign badge_color = "#0b7285" %}
        {% when "open-source" %}
          {% assign badge_color = "#2f9e44" %}
        {% else %}
          {% assign badge_color = "#6c757d" %}
      {% endcase %}
      {% include project_list_item.liquid project=project badge_color=badge_color %}
    {% endfor %}
  </ol>
{% endif %}
</div>
