{% assign project = include.project %}
{% assign badge_color = include.badge_color %}
{% assign project_link = project.url | relative_url %}
{% assign project_link_external = false %}
{% if project.website %}
  {% assign project_link = project.website %}
  {% if project.website contains '://' %}
    {% assign project_link_external = true %}
  {% endif %}
{% endif %}

{% if project.preview %}
  {% assign preview_lower = project.preview | downcase %}
  {% assign preview_is_video = false %}
  {% if preview_lower contains '.mp4' or preview_lower contains '.webm' or preview_lower contains '.ogg' %}
    {% assign preview_is_video = true %}
  {% endif %}

  {% if project.preview contains '://' %}
    {% assign preview_path = project.preview %}
  {% else %}
    {% assign preview_first_character = project.preview | slice: 0 %}
    {% if preview_first_character == '/' %}
      {% assign preview_path = project.preview | relative_url %}
    {% else %}
      {% assign preview_path = project.preview | prepend: '/assets/img/projects/' | relative_url %}
    {% endif %}
  {% endif %}

  {% assign lightbox_path = '' %}
  {% assign lightbox_is_embed = false %}
  {% if project.video %}
    {% assign lightbox_path = project.video %}
    {% assign lightbox_lower = project.video | downcase %}
    {% if lightbox_lower contains 'drive.google.com/file/d/' or lightbox_lower contains 'youtube.com/embed/' or lightbox_lower contains 'player.vimeo.com/video/' %}
      {% assign lightbox_is_embed = true %}
    {% endif %}
  {% elsif preview_is_video %}
    {% assign lightbox_path = preview_path %}
  {% endif %}

  {% assign preview_mime_type = 'video/mp4' %}
  {% if preview_lower contains '.webm' %}
    {% assign preview_mime_type = 'video/webm' %}
  {% elsif preview_lower contains '.ogg' %}
    {% assign preview_mime_type = 'video/ogg' %}
  {% endif %}

  {% if project.video or preview_is_video %}
    <button
      class="publication-preview-button project-preview"
      type="button"
      data-publication-video-src="{{ lightbox_path | escape }}"
      data-publication-video-type="{{ preview_mime_type }}"
      data-publication-video-embed="{{ lightbox_is_embed }}"
      data-publication-video-title="{{ project.title | escape }}"
      aria-label="Open {{ project.title | escape }} preview"
    >
      {% if preview_is_video %}
        <video
          class="preview publication-preview-video z-depth-1 rounded"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          aria-hidden="true"
        >
          <source src="{{ preview_path }}" type="{{ preview_mime_type }}">
        </video>
      {% else %}
        <img class="preview publication-preview-image z-depth-1 rounded" src="{{ preview_path }}" alt="{{ project.title | escape }}">
      {% endif %}
    </button>
  {% else %}
    <a
      class="publication-preview-link project-preview"
      href="{{ project_link }}"
      aria-label="Open {{ project.title | escape }}"
      {% if project_link_external %}target="_blank" rel="external nofollow noopener"{% endif %}
    >
      <img class="preview publication-preview-image z-depth-1 rounded" src="{{ preview_path }}" alt="{{ project.title | escape }}">
    </a>
  {% endif %}

  {% if project.video or preview_is_video %}
    <script>
      if (!window.publicationVideoLightboxReady) {
        window.publicationVideoLightboxReady = true;
        document.addEventListener("click", function (event) {
          const trigger = event.target.closest("[data-publication-video-src]");
          const lightbox = event.target.closest("[data-publication-video-lightbox]");

          if (trigger) {
            const src = trigger.getAttribute("data-publication-video-src");
            const type = trigger.getAttribute("data-publication-video-type") || "video/mp4";
            const isEmbed = trigger.getAttribute("data-publication-video-embed") === "true";
            const title = trigger.getAttribute("data-publication-video-title") || "Preview";
            const existing = document.querySelector("[data-publication-video-lightbox]");
            if (existing) existing.remove();

            const overlay = document.createElement("div");
            overlay.className = "publication-video-lightbox";
            overlay.setAttribute("data-publication-video-lightbox", "");

            const dialog = document.createElement("div");
            dialog.className = "publication-video-lightbox__dialog";
            dialog.setAttribute("role", "dialog");
            dialog.setAttribute("aria-modal", "true");
            dialog.setAttribute("aria-label", title);

            const closeButton = document.createElement("button");
            closeButton.className = "publication-video-lightbox__close";
            closeButton.type = "button";
            closeButton.setAttribute("aria-label", "Close preview");
            closeButton.textContent = "\u00d7";

            dialog.appendChild(closeButton);

            if (isEmbed) {
              const iframe = document.createElement("iframe");
              iframe.className = "publication-video-lightbox__frame";
              iframe.src = src;
              iframe.title = title;
              iframe.allow = "autoplay; encrypted-media; fullscreen; picture-in-picture";
              iframe.allowFullscreen = true;
              iframe.tabIndex = -1;
              dialog.appendChild(iframe);
            } else {
              const video = document.createElement("video");
              video.className = "publication-video-lightbox__video";
              video.controls = true;
              video.autoplay = true;
              video.loop = true;
              video.playsInline = true;
              video.tabIndex = -1;

              const source = document.createElement("source");
              source.src = src;
              source.type = type;

              video.appendChild(source);
              dialog.appendChild(video);
            }

            overlay.appendChild(dialog);
            document.body.appendChild(overlay);
            document.body.classList.add("publication-video-lightbox-open");
            dialog.querySelector(".publication-video-lightbox__video, .publication-video-lightbox__frame").focus();
            return;
          }

          if (
            lightbox &&
            (event.target.matches("[data-publication-video-lightbox]") ||
              event.target.matches(".publication-video-lightbox__close"))
          ) {
            lightbox.remove();
            document.body.classList.remove("publication-video-lightbox-open");
          }
        });

        document.addEventListener("keydown", function (event) {
          if (event.key !== "Escape") return;
          const lightbox = document.querySelector("[data-publication-video-lightbox]");
          if (!lightbox) return;
          lightbox.remove();
          document.body.classList.remove("publication-video-lightbox-open");
        });
      }
    </script>
  {% endif %}
{% else %}
  <abbr class="badge rounded w-100" style="background-color:{{ badge_color }}">{{ project.category | upcase }}</abbr>
{% endif %}
